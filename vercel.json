{
  "version": 2,
  "buildCommand": "npm install && node node_modules/vite/bin/vite.js build client -c vite.config.ts && node_modules/.bin/esbuild api/index.ts --bundle --platform=node --target=node20 --outfile=api/bundle.js --external:pg-native --external:fsevents",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/email-daily", "schedule": "0 11 * * *" },
    { "path": "/api/cron/abandoned-cart", "schedule": "0 15 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy",   "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://salvitarn.com.br https://*.salvitarn.com.br https://www.facebook.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.facebook.com https://*.facebook.net; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/sal-vita-admin",
      "has": [{ "type": "host", "value": "premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/sal-vita-admin",
      "has": [{ "type": "host", "value": "www\\.premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/sal-vita-recovery",
      "has": [{ "type": "host", "value": "premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/sal-vita-recovery",
      "has": [{ "type": "host", "value": "www\\.premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/meu-pedido",
      "has": [{ "type": "host", "value": "premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/meu-pedido",
      "has": [{ "type": "host", "value": "www\\.premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/atacado",
      "has": [{ "type": "host", "value": "premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/atacado",
      "has": [{ "type": "host", "value": "www\\.premium\\.salvitarn\\.com\\.br" }],
      "dest": "/index.html"
    },
    {
      "src": "/api/(.*)",
      "has": [{ "type": "host", "value": "premium\\.salvitarn\\.com\\.br" }],
      "dest": "/api/bundle.js"
    },
    {
      "src": "/api/(.*)",
      "has": [{ "type": "host", "value": "www\\.premium\\.salvitarn\\.com\\.br" }],
      "dest": "/api/bundle.js"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "www\\.premium\\.salvitarn\\.com\\.br" }],
      "dest": "/sal-vita"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "premium\\.salvitarn\\.com\\.br" }],
      "dest": "/sal-vita"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/bundle.js"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot|map|webmanifest|json|txt|xml))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
