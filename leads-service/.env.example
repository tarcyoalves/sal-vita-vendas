# String de conexão do banco Neon Postgres (mesmo banco do sal-vita-vendas ou outro)
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# Endereço e chave da Evolution API (já instalada na VPS Oracle)
WA_SERVER_URL=https://evolution.salvitarn.com.br
WA_API_KEY=MinhaChaveSuperSegura123456

# Segredo que a Evolution deve enviar para validar o webhook (evita chamadas falsas)
WEBHOOK_SECRET=defina-uma-string-aleatoria-aqui

# Provedores de IA (mesmas chaves usadas no sal-vita-vendas)
GEMINI_API_KEY=
GROQ_API_KEY=

# Porta em que este serviço vai escutar
PORT=3100
