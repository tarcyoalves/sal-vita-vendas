{
  "name": "sallog",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:admin\"",
    "dev:api": "tsx watch api/index.ts",
    "dev:admin": "vite admin --config admin/vite.config.ts",
    "build": "npm run build:api && npm run build:admin",
    "build:api": "esbuild api/index.ts --bundle --platform=node --target=node20 --outfile=api/bundle.js --external:pg-native --external:fsevents",
    "build:admin": "vite build admin --config admin/vite.config.ts",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@tanstack/react-query": "^5.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^4.2.1",
    "leaflet": "^1.9.4",
    "superjson": "^2.2.1",
    "wouter": "^3.3.5",
    "zod": "^3.23.8",
    "sonner": "^1.7.4",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/leaflet": "^1.9.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.24.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.6"
  }
}
