{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "paths": {
      "@sallog/shared": ["./shared/index.ts"]
    }
  },
  "include": ["api/**/*", "admin/src/**/*", "shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
